# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,jamii-afya-production.up.railway.app
# Production: https://your-frontend.example https://your-api.example (required when using HTTPS + cookies)
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional (rate limits for ScopedRateThrottle on auth): THROTTLE_LOGIN THROTTLE_OTP_SEND THROTTLE_OTP_VERIFY
# Optional (lockouts): AUTH_LOGIN_MAX_ATTEMPTS AUTH_LOGIN_LOCKOUT_SECONDS AUTH_OTP_VERIFY_MAX_ATTEMPTS AUTH_OTP_VERIFY_LOCKOUT_SECONDS

# ── Database ──────────────────────────────────────────────────────────────────
# Railway (and many hosts): use DATABASE_URL (Postgres) or MYSQL_URL — omit DB_* when set.
# Local MySQL: set the variables below.
DB_NAME=jamii_fund
DB_USER=root
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=3306

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── M-Pesa Daraja API ─────────────────────────────────────────────────────────
# sandbox | production
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-lipa-na-mpesa-passkey

# Publicly reachable HTTPS URLs (use ngrok during dev).
# For production, append the same ?token= value as MPESA_WEBHOOK_SECRET to each callback URL in Daraja.
MPESA_CALLBACK_URL=https://YOUR_DOMAIN/api/mpesa/callback/?token=GENERATE_A_LONG_RANDOM_SECRET
MPESA_B2C_RESULT_URL=https://YOUR_DOMAIN/api/mpesa/b2c/result/?token=GENERATE_A_LONG_RANDOM_SECRET
MPESA_B2C_QUEUE_TIMEOUT_URL=https://YOUR_DOMAIN/api/mpesa/b2c/timeout/?token=GENERATE_A_LONG_RANDOM_SECRET
# Must match the ?token= query on callback URLs (or set X-Mpesa-Webhook-Secret / Bearer at reverse proxy).
MPESA_WEBHOOK_SECRET=
# Optional: comma-separated Safaricom egress IPs (defense in depth).
MPESA_CALLBACK_ALLOWED_IPS=

# B2C (outbound payments)
MPESA_B2C_INITIATOR=your-initiator-name
MPESA_B2C_SECURITY_CREDENTIAL=your-encrypted-credential

# ── CommsGrid SMS ────────────────────────────────────────────────────────────
COMMSGRID_API_KEY=your-commsgrid-api-key
COMMSGRID_SENDER_ID=JamiiAfya

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
