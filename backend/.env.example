# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── MySQL ─────────────────────────────────────────────────────────────────────
DB_NAME=jamii_fund
DB_USER=root
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=3306

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── M-Pesa Daraja API ─────────────────────────────────────────────────────────
# sandbox | production
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-lipa-na-mpesa-passkey

# Publicly reachable HTTPS URLs (use ngrok during dev)
MPESA_CALLBACK_URL=https://YOUR_DOMAIN/api/mpesa/callback/
MPESA_B2C_RESULT_URL=https://YOUR_DOMAIN/api/mpesa/b2c/result/
MPESA_B2C_QUEUE_TIMEOUT_URL=https://YOUR_DOMAIN/api/mpesa/b2c/timeout/

# B2C (outbound payments)
MPESA_B2C_INITIATOR=your-initiator-name
MPESA_B2C_SECURITY_CREDENTIAL=your-encrypted-credential

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
